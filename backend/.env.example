# Backend Environment Variables
# Copy this file to .env and fill in your values

# MongoDB Connection
# Get from: https://cloud.mongodb.com (MongoDB Atlas)
MONGO_URL=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority
DB_NAME=dommma

# CORS Origins (comma-separated domains, or * for all)
CORS_ORIGINS=https://your-domain.com,https://www.your-domain.com

# Anthropic API Key (for Nova AI chatbot)
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# OpenAI API Key (optional, for additional AI features)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here

# Stripe API Key (for payments)
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_API_KEY=sk_live_your-stripe-key-here

# Resend API Key (for transactional emails)
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_your-resend-key-here
SENDER_EMAIL=noreply@dommma.com
CONTACT_EMAIL=support@dommma.com
ADMIN_EMAIL=rgoswami@dommma.com

# Admin Tools
ADMIN_SECRET_KEY=your-secure-admin-key

# Google OAuth (for social login)
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-secret-here

# DocuSign Integration (for e-signatures)
# Get from: https://admindemo.docusign.com/apps-and-keys
DOCUSIGN_INTEGRATION_KEY=your-integration-key
DOCUSIGN_ACCOUNT_ID=your-account-id
DOCUSIGN_BASE_URL=https://demo.docusign.net/restapi
DOCUSIGN_AUTH_SERVER=account-d.docusign.com
DOCUSIGN_REDIRECT_URI=https://your-domain.com/api/docusign/callback
DOCUSIGN_CLIENT_SECRET=your-client-secret

# Perplexity API Key (for market analysis)
# Get from: https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=pplx-your-key-here

# Cloudflare R2 Storage (for file uploads)
# Get from: https://dash.cloudflare.com/ -> R2 -> Manage R2 API Tokens
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY=your-access-key
R2_SECRET_KEY=your-secret-key
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_BUCKET=dommma-files
